{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 AccountingScholarships.API",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-api",
            "program": "${workspaceFolder}/AccountingScholarships.API/bin/Debug/net8.0/AccountingScholarships.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/AccountingScholarships.API",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            }
        },
        {
            "name": "🌐 API + Browser",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-api",
            "program": "${workspaceFolder}/AccountingScholarships.API/bin/Debug/net8.0/AccountingScholarships.API.dll",
            "args": [],
            "cwd": "${workspaceFolder}/AccountingScholarships.API",
            "stopAtEntry": false,
            "launchBrowser": {
                "enabled": true,
                "args": "${auto-detect-url}/swagger",
                "windows": {
                    "command": "cmd.exe",
                    "args": "/C start ${auto-detect-url}/swagger"
                }
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ]
}
